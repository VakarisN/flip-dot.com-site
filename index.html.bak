<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<title>FlipDot Remote</title>
<style>
:root {
  --bg: #0e0e0e; --panel: #1a1a1a; --panel2: #242424;
  --text: #f0f0f0; --dim: #888; --accent: #f5a623;
  --ok: #2ecc71; --err: #e74c3c; --border: #2a2a2a;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif;
       min-height: 100vh; display: flex; flex-direction: column; }

/* ── Auth screen ─────────────────────────────── */
#authScreen { display: flex; flex-direction: column; align-items: center;
              justify-content: center; flex: 1; padding: 2rem; text-align: center; }
#authScreen .logo { font-size: 2.5rem; letter-spacing: .25em; margin-bottom: 1rem; }
#authScreen h1 { font-size: 1.4rem; font-weight: 600; margin-bottom: .4rem; }
#authScreen p { color: var(--dim); margin-bottom: 2rem; font-size: .95rem; }
#authScreen button { display: flex; align-items: center; gap: 10px; padding: 12px 24px;
  background: #fff; color: #222; border: none; border-radius: 8px; font-size: 1rem;
  cursor: pointer; font-weight: 500; }
#authScreen button img { width: 20px; height: 20px; }

/* ── Pending screen ──────────────────────────── */
#pendingScreen { display: none; flex-direction: column; align-items: center;
                 justify-content: center; flex: 1; padding: 2rem; text-align: center; }
#pendingScreen .logo { font-size: 2.5rem; letter-spacing: .25em; margin-bottom: 1.5rem; }
#pendingScreen h2 { margin-bottom: .5rem; }
#pendingScreen p { color: var(--dim); max-width: 320px; line-height: 1.5; }
#pendingUser { font-size: .85rem; color: var(--dim); margin-top: 1.5rem; }
#btnSignOut2 { margin-top: 1rem; background: none; border: 1px solid #444;
               color: var(--dim); padding: 8px 18px; border-radius: 6px; cursor: pointer; }

/* ── Main app ────────────────────────────────── */
#app { display: none; flex-direction: column; flex: 1; max-width: 480px;
       width: 100%; margin: 0 auto; }
header { padding: 12px 16px; display: flex; align-items: center; justify-content: space-between;
         border-bottom: 1px solid var(--border); }
header .logo { font-size: 1.1rem; letter-spacing: .15em; font-weight: 600; }
header .user { display: flex; align-items: center; gap: 8px; }
header .user img { width: 28px; height: 28px; border-radius: 50%; }
header .user span { font-size: .8rem; color: var(--dim); }
#btnSignOut { background: none; border: 1px solid #333; color: var(--dim);
              padding: 4px 10px; border-radius: 5px; cursor: pointer; font-size: .8rem; }

nav { display: flex; border-bottom: 1px solid var(--border); background: var(--panel); overflow-x: auto; }
nav button { flex: 1; min-width: 60px; padding: 11px 4px; background: none; border: none;
             color: var(--dim); font-size: .82rem; cursor: pointer; border-bottom: 2px solid transparent; }
nav button.active { color: var(--accent); border-bottom-color: var(--accent); }

main { flex: 1; overflow-y: auto; }
section.tab { display: none; padding: 14px; }
section.tab.active { display: block; }

.card { background: var(--panel); border-radius: 12px; padding: 16px; margin-bottom: 12px; }
.row-label { font-size: .75rem; text-transform: uppercase; letter-spacing: .06em;
             color: var(--dim); margin-bottom: 8px; }
.hint { font-size: .8rem; color: var(--dim); line-height: 1.45; margin-bottom: 6px; }

input[type=text], textarea, select {
  width: 100%; padding: 10px 12px; background: var(--panel2); color: var(--text);
  border: 1px solid #333; border-radius: 8px; font-size: .95rem; margin-bottom: 8px; }
textarea { resize: vertical; min-height: 70px; }
input[type=date], input[type=time] {
  width: 100%; padding: 10px 12px; background: var(--panel2); color: var(--text);
  border: 1px solid #333; border-radius: 8px; font-size: .95rem; margin-bottom: 8px; }

button.primary { width: 100%; padding: 13px; background: var(--accent); color: #111;
                 border: none; border-radius: 9px; font-size: 1rem; font-weight: 600; cursor: pointer; }
button.secondary { width: 100%; padding: 12px; background: var(--panel2); color: var(--text);
                   border: 1px solid #444; border-radius: 9px; font-size: .95rem; cursor: pointer; }
button.ghost { width: 100%; padding: 10px; background: none; color: var(--dim);
               border: 1px solid #333; border-radius: 9px; font-size: .9rem; cursor: pointer; }
button:disabled { opacity: .4; cursor: not-allowed; }
button.active-state { background: #1a3a1a; border-color: var(--ok); color: var(--ok); }

/* display preview */
#preview { display: grid; background: #111; border-radius: 8px; margin-bottom: 10px; gap: 1px; }
.dp { width: 8px; height: 8px; border-radius: 50%; background: #1e1e1e; }
.dp.on { background: var(--accent); box-shadow: 0 0 4px var(--accent); }

/* status bar */
#statusBar { padding: 6px 14px; font-size: .75rem; color: var(--dim);
             border-top: 1px solid var(--border); text-align: center; }
#statusBar .ok  { color: var(--ok); }
#statusBar .err { color: var(--err); }

/* toast */
#toast { position: fixed; bottom: 60px; left: 50%; transform: translateX(-50%) translateY(20px);
         background: #222; color: var(--text); padding: 9px 18px; border-radius: 8px;
         font-size: .9rem; opacity: 0; transition: all .25s; pointer-events: none; white-space: nowrap; }
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* admin */
.user-row { display: flex; align-items: center; gap: 10px; padding: 10px 0;
            border-bottom: 1px solid var(--border); }
.user-row img { width: 36px; height: 36px; border-radius: 50%; }
.user-row .info { flex: 1; min-width: 0; }
.user-row .info .name { font-size: .9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.user-row .info .email { font-size: .75rem; color: var(--dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.badge { font-size: .7rem; padding: 2px 8px; border-radius: 10px; margin-right: 4px; }
.badge.pending  { background: #2a2000; color: #f5a623; }
.badge.approved { background: #0a2a0a; color: var(--ok); }
.badge.rejected { background: #2a0a0a; color: var(--err); }
.user-row .actions button { padding: 5px 10px; border-radius: 5px; border: 1px solid #444;
                             background: none; color: var(--text); font-size: .78rem; cursor: pointer; }

/* anim selector */
.anim-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; margin-bottom: 8px; }
.anim-chip { padding: 8px 4px; background: var(--panel2); border: 1px solid #333; border-radius: 6px;
             font-size: .78rem; text-align: center; cursor: pointer; color: var(--dim); }
.anim-chip.sel { border-color: var(--accent); color: var(--accent); background: #1a1200; }

/* local redirect banner */
#localBanner { background: #1a1a00; border: 1px solid #443300; border-radius: 10px;
               padding: 14px; margin: 14px; text-align: center; }
#localBanner p { font-size: .9rem; margin-bottom: 10px; color: #ccc; }
#localBanner a { display: inline-block; padding: 10px 20px; background: var(--accent);
                 color: #111; border-radius: 8px; text-decoration: none; font-weight: 600; }
</style>
</head>
<body>

<!-- ── Auth screen ─────────────────────────────────────── -->
<div id="authScreen">
  <div class="logo">● ○ ● ○ ●</div>
  <h1>FlipDot Remote</h1>
  <p>Sign in to control the display remotely.</p>
  <button id="btnGoogle">
    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="G">
    Sign in with Google
  </button>
</div>

<!-- ── Pending approval ────────────────────────────────── -->
<div id="pendingScreen">
  <div class="logo">● ○ ● ○ ●</div>
  <h2>Waiting for approval</h2>
  <p>Your account has been registered. The owner needs to approve you before you can control the display.</p>
  <div id="pendingUser"></div>
  <button id="btnSignOut2">Sign out</button>
</div>

<!-- ── Main app ────────────────────────────────────────── -->
<div id="app">
  <header>
    <div class="logo">● FlipDot</div>
    <div class="user">
      <img id="userAvatar" src="" alt="">
      <span id="userName"></span>
      <button id="btnSignOut">Sign out</button>
    </div>
  </header>

  <nav id="tabs">
    <button data-tab="compose" class="active">Text</button>
    <button data-tab="time">Time</button>
    <button data-tab="spotify">Spotify</button>
    <button data-tab="admin" id="adminTabBtn" style="display:none">Admin</button>
  </nav>

  <main>

    <!-- ── COMPOSE ── -->
    <section id="tab-compose" class="tab active">
      <div class="card">
        <div class="row-label">Message</div>
        <textarea id="msgText" placeholder="Type your message…" maxlength="300"></textarea>

        <div class="row-label">Animation</div>
        <div class="anim-grid" id="animGrid"></div>

        <div class="row-label">Speed</div>
        <input type="range" id="speedSlider" min="1" max="10" value="7" style="width:100%;margin-bottom:8px">

        <button class="primary" id="btnSend">Send to display</button>
        <div style="display:flex;gap:8px;margin-top:8px">
          <button class="secondary" id="btnClear" style="flex:1">Clear</button>
          <button class="secondary" id="btnFill" style="flex:1">Fill</button>
          <button class="secondary" id="btnStop" style="flex:1">Stop</button>
        </div>
      </div>

      <div id="localBanner" style="display:none">
        <p>🎮 For Snake and the full editor, open the local address:</p>
        <a id="localLink" href="#">Open local app</a>
      </div>
    </section>

    <!-- ── TIME ── -->
    <section id="tab-time" class="tab">
      <div class="card">
        <div class="row-label">Clock mode</div>
        <p class="hint">Display becomes an NTP clock until you send something else.</p>
        <button class="secondary" id="btnClock">Start clock on display</button>
      </div>
      <div class="card">
        <div class="row-label">Countdown</div>
        <p class="hint">Show days remaining to a date, or hours:mins to a time.</p>
        <select id="cdType" style="margin-bottom:8px">
          <option value="date">Date — days remaining</option>
          <option value="time">Time — hours:mins remaining</option>
        </select>
        <div id="cdDateRow">
          <div class="row-label">Target date</div>
          <input type="date" id="cdDate">
        </div>
        <div id="cdTimeRow" style="display:none">
          <div class="row-label">Target time</div>
          <input type="time" id="cdTime">
        </div>
        <div class="row-label">Label (optional)</div>
        <input type="text" id="cdLabel" placeholder="e.g. XMAS  →  5 DAYS TO XMAS" maxlength="16" style="margin-bottom:8px">
        <button class="secondary" id="btnCdSend">Show on display</button>
        <button class="ghost" id="btnCdAuto" style="margin-top:6px">Auto-update every minute: off</button>
      </div>
    </section>

    <!-- ── SPOTIFY ── -->
    <section id="tab-spotify" class="tab">
      <div class="card">
        <div class="row-label">Spotify — Now Playing</div>
        <div id="spStatus2" style="font-size:13px;margin:6px 0 10px;color:var(--dim)">○ Not connected</div>
        <div id="spSetupHint2">
          <p class="hint">Setup: <a href="https://developer.spotify.com/dashboard" target="_blank" style="color:var(--accent)">developer.spotify.com</a> → create free app → Redirect URI:</p>
          <code id="spUri2" style="display:block;background:var(--panel2);padding:8px 10px;border-radius:6px;font-size:12px;margin:6px 0 10px;word-break:break-all;color:var(--accent)">https://flip-dot.com/callback</code>
          <div class="row-label">Spotify Client ID</div>
          <input type="text" id="spClientId2" placeholder="Paste Client ID" autocomplete="off" spellcheck="false" style="margin-bottom:10px">
        </div>
        <button class="secondary" id="btnSpConnect2">Connect Spotify</button>
        <button class="ghost" id="btnSpDisconnect2" style="margin-top:6px;display:none">Disconnect</button>
        <button class="primary" id="btnSpAuto2" style="margin-top:10px" disabled>▶ Auto-update when song changes</button>
        <p class="hint" style="margin-top:8px">Scrolls new track in once, then holds it. Checks every 30 s.</p>
      </div>
    </section>

    <!-- ── ADMIN ── -->
    <section id="tab-admin" class="tab">
      <div class="card">
        <div class="row-label">Pending users</div>
        <div id="userListPending"><p class="hint">No pending users.</p></div>
      </div>
      <div class="card">
        <div class="row-label">Approved users</div>
        <div id="userListApproved"><p class="hint">No approved users.</p></div>
      </div>
      <div class="card">
        <div class="row-label">Device URL (local ESP32 address)</div>
        <p class="hint">Stored locally. Used to link users back to the local app.</p>
        <input type="text" id="localUrlInput" placeholder="http://192.168.0.144">
        <button class="secondary" id="btnSaveLocal">Save</button>
      </div>
    </section>

  </main>

  <div id="statusBar">Connecting…</div>
</div>

<div id="toast"></div>

<!-- ── Firebase SDK ──────────────────────────────────────── -->
<script type="module">
import { initializeApp }                      from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getAuth, GoogleAuthProvider,
         signInWithPopup, signOut,
         onAuthStateChanged }                 from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
import { getFirestore, doc, getDoc, setDoc,
         collection, onSnapshot, updateDoc }  from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";
import { getDatabase, ref, set, remove }      from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";

// ── Config ──────────────────────────────────────────────────
const FB = initializeApp({
  apiKey:            "AIzaSyBdBP7Zhu7ZMnGwoxiZzgeMxak4chwg8-E",
  authDomain:        "flip-dott.firebaseapp.com",
  databaseURL:       "https://flip-dott-default-rtdb.europe-west1.firebasedatabase.app",
  projectId:         "flip-dott",
  storageBucket:     "flip-dott.firebasestorage.app",
  messagingSenderId: "441747453633",
  appId:             "1:441747453633:web:7a18596ca8c2a2f61e0640"
});
const auth = getAuth(FB);
const db   = getFirestore(FB);
const rtdb = getDatabase(FB);

// ── Admin emails (add yours here) ────────────────────────────
const ADMINS = ["vakarisneverauskas@gmail.com"];

// ── Helpers ──────────────────────────────────────────────────
const $ = id => document.getElementById(id);
let toastT;
function toast(msg, type) {
  const el = $("toast"); el.textContent = msg;
  el.style.borderLeft = type === "err" ? "3px solid var(--err)" :
                        type === "ok"  ? "3px solid var(--ok)"  : "none";
  el.classList.add("show"); clearTimeout(toastT);
  toastT = setTimeout(() => el.classList.remove("show"), 3000);
}

function show(id) {
  ["authScreen","pendingScreen","app"].forEach(s => {
    const el = $(s); if (el) el.style.display = (s === id) ? (id === "app" ? "flex" : "flex") : "none";
  });
}

// ── Send command to RTDB ─────────────────────────────────────
async function sendCmd(cmd) {
  try {
    const cmdRef = ref(rtdb, "cmd");
    await set(cmdRef, { ...cmd, ts: Date.now() });
    toast("Sent ✓", "ok");
  } catch(e) { toast("Send failed: " + e.message, "err"); }
}

// ── Tab switching ─────────────────────────────────────────────
document.querySelectorAll("nav button[data-tab]").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll("nav button").forEach(b => b.classList.remove("active"));
    document.querySelectorAll("section.tab").forEach(s => s.classList.remove("active"));
    btn.classList.add("active");
    const sec = $("tab-" + btn.dataset.tab);
    if (sec) sec.classList.add("active");
  });
});

// ── Animation chips ───────────────────────────────────────────
const ANIMS = ["none","marquee","scrollv","typewriter","wipe","curtain",
               "dissolve","wave","bounce","splitflap","blink","sparkle"];
const ANIM_LABELS = { none:"Static", marquee:"Scroll", scrollv:"Scroll ↕",
  typewriter:"Typewrite", wipe:"Wipe", curtain:"Curtain", dissolve:"Dissolve",
  wave:"Wave", bounce:"Bounce", splitflap:"Splitflap", blink:"Blink", sparkle:"Sparkle" };
let selAnim = "marquee";
const grid = $("animGrid");
ANIMS.forEach(a => {
  const ch = document.createElement("div");
  ch.className = "anim-chip" + (a === selAnim ? " sel" : "");
  ch.textContent = ANIM_LABELS[a]; ch.dataset.anim = a;
  ch.addEventListener("click", () => {
    document.querySelectorAll(".anim-chip").forEach(c => c.classList.remove("sel"));
    ch.classList.add("sel"); selAnim = a;
  });
  grid.appendChild(ch);
});

// ── Compose ───────────────────────────────────────────────────
$("btnSend").addEventListener("click", async () => {
  const text = $("msgText").value.trim();
  if (!text) { toast("Type a message first", "err"); return; }
  const speed = parseInt($("speedSlider").value);
  const delay = Math.round(200 - speed * 18);
  await sendCmd({ type: "text", text: text.toUpperCase(), anim: selAnim, delay, loop: 0 });
});
$("btnClear").addEventListener("click", () => sendCmd({ type: "clear" }));
$("btnFill").addEventListener("click",  () => sendCmd({ type: "fill"  }));
$("btnStop").addEventListener("click",  () => sendCmd({ type: "stop"  }));

// ── Local banner ─────────────────────────────────────────────
function updateLocalBanner() {
  const url = localStorage.getItem("localDeviceUrl");
  const banner = $("localBanner");
  if (url) { $("localLink").href = url; banner.style.display = ""; }
  else banner.style.display = "none";
}

// ── Clock ─────────────────────────────────────────────────────
$("btnClock").addEventListener("click", () => {
  const tz = -new Date().getTimezoneOffset();
  sendCmd({ type: "clock", tz });
});

// ── Countdown ────────────────────────────────────────────────
let cdAutoTimer = null;
$("cdType").addEventListener("change", () => {
  const t = $("cdType").value;
  $("cdDateRow").style.display = t === "date" ? "" : "none";
  $("cdTimeRow").style.display = t === "time" ? "" : "none";
});
function cdText() {
  const type = $("cdType").value;
  const label = ($("cdLabel").value || "").toUpperCase().trim();
  if (type === "date") {
    const d = new Date($("cdDate").value); if (!$("cdDate").value) return null;
    const days = Math.ceil((d - new Date().setHours(0,0,0,0)) / 86400000);
    const base = days + (days === 1 ? " DAY" : " DAYS");
    return label ? base + " TO " + label : base;
  } else {
    if (!$("cdTime").value) return null;
    const [h,m] = $("cdTime").value.split(":").map(Number);
    const now = new Date(); const then = new Date();
    then.setHours(h, m, 0, 0); if (then < now) then.setDate(then.getDate() + 1);
    const diff = Math.round((then - now) / 60000);
    const base = Math.floor(diff/60) + ":" + String(diff%60).padStart(2,"0");
    return label ? base + " TO " + label : base;
  }
}
async function cdSend() {
  const t = cdText(); if (!t) { toast("Set a target first", "err"); return; }
  const anim = t.length > 8 ? "marquee" : "none";
  await sendCmd({ type: "text", text: t, anim, delay: 74, loop: anim === "none" ? 1 : 0 });
}
$("btnCdSend").addEventListener("click", cdSend);
$("btnCdAuto").addEventListener("click", () => {
  if (cdAutoTimer) {
    clearInterval(cdAutoTimer); cdAutoTimer = null;
    $("btnCdAuto").textContent = "Auto-update every minute: off";
  } else {
    cdSend();
    cdAutoTimer = setInterval(cdSend, 60000);
    $("btnCdAuto").textContent = "Auto-update every minute: on";
  }
});

// ── Spotify PKCE ─────────────────────────────────────────────
// (reuses same sha256Sync from ESP32 app — pure-JS SHA-256)
function sha256Sync(str) {
  const K=[0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2];
  let h=[0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19];
  const b=Array.from(new TextEncoder().encode(str));
  const bl=b.length*8;b.push(0x80);
  while(b.length%64!==56)b.push(0);
  for(let i=7;i>=0;i--)b.push((bl/Math.pow(2,i*8))&0xff);
  for(let i=0;i<b.length;i+=64){
    const w=new Array(64);
    for(let j=0;j<16;j++)w[j]=(b[i+j*4]<<24)|(b[i+j*4+1]<<16)|(b[i+j*4+2]<<8)|b[i+j*4+3];
    for(let j=16;j<64;j++){const s0=(w[j-15]>>>7|w[j-15]<<25)^(w[j-15]>>>18|w[j-15]<<14)^(w[j-15]>>>3);const s1=(w[j-2]>>>17|w[j-2]<<15)^(w[j-2]>>>19|w[j-2]<<13)^(w[j-2]>>>10);w[j]=(w[j-16]+s0+w[j-7]+s1)>>>0;}
    let[a,b2,c,d,e,f,g,hh]=h;
    for(let j=0;j<64;j++){const S1=(e>>>6|e<<26)^(e>>>11|e<<21)^(e>>>25|e<<7);const ch=(e&f)^(~e&g);const t1=(hh+S1+ch+K[j]+w[j])>>>0;const S0=(a>>>2|a<<30)^(a>>>13|a<<19)^(a>>>22|a<<10);const maj=(a&b2)^(a&c)^(b2&c);const t2=(S0+maj)>>>0;hh=g;g=f;f=e;e=(d+t1)>>>0;d=c;c=b2;b2=a;a=(t1+t2)>>>0;}
    h=h.map((v,i)=>([a,b2,c,d,e,f,g,hh][i]+v)>>>0);
  }
  const out=new Uint8Array(32);h.forEach((v,i)=>{out[i*4]=(v>>>24)&0xff;out[i*4+1]=(v>>>16)&0xff;out[i*4+2]=(v>>>8)&0xff;out[i*4+3]=v&0xff;});
  return out;
}
async function sha256Bytes(str) {
  if (window.crypto && crypto.subtle)
    return new Uint8Array(await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str)));
  return sha256Sync(str);
}
function spB64(buf) {
  return btoa(String.fromCharCode(...(buf instanceof Uint8Array ? buf : new Uint8Array(buf))))
    .replace(/\+/g,"-").replace(/\//g,"_").replace(/=+$/,"");
}

async function spConnect2() {
  const cid = $("spClientId2").value.trim();
  if (!cid) { toast("Enter Spotify Client ID first", "err"); return; }
  const verifier = spB64(crypto.getRandomValues(new Uint8Array(32)));
  const challenge = spB64(await sha256Bytes(verifier));
  localStorage.setItem("sp_v2", verifier); localStorage.setItem("sp_cid2", cid);
  location.href = "https://accounts.spotify.com/authorize?" + new URLSearchParams({
    client_id: cid, response_type: "code",
    redirect_uri: "https://flip-dot.com/callback",
    code_challenge_method: "S256", code_challenge: challenge,
    scope: "user-read-currently-playing user-read-playback-state",
    state: btoa(location.origin + "/")
  });
}

async function spExchange2(code) {
  const r = await fetch("https://accounts.spotify.com/api/token", {
    method: "POST", headers: { "Content-Type": "application/x-www-form-urlencoded" },
    body: new URLSearchParams({ client_id: localStorage.getItem("sp_cid2")||"",
      grant_type: "authorization_code", code,
      redirect_uri: "https://flip-dot.com/callback",
      code_verifier: localStorage.getItem("sp_v2")||"" })
  });
  if (!r.ok) throw new Error("Token exchange failed (" + r.status + ")");
  const t = await r.json();
  localStorage.setItem("sp_at2", t.access_token);
  if (t.refresh_token) localStorage.setItem("sp_rt2", t.refresh_token);
  localStorage.setItem("sp_exp2", Date.now() + t.expires_in * 1000);
}

async function spToken2() {
  const exp = parseInt(localStorage.getItem("sp_exp2")||"0");
  if (Date.now() < exp - 60000) return localStorage.getItem("sp_at2");
  const rt = localStorage.getItem("sp_rt2"); if (!rt) return null;
  const r = await fetch("https://accounts.spotify.com/api/token", {
    method: "POST", headers: { "Content-Type": "application/x-www-form-urlencoded" },
    body: new URLSearchParams({ grant_type: "refresh_token", refresh_token: rt,
      client_id: localStorage.getItem("sp_cid2")||"" })
  });
  if (!r.ok) { ["sp_at2","sp_rt2","sp_exp2"].forEach(k=>localStorage.removeItem(k)); return null; }
  const t = await r.json();
  localStorage.setItem("sp_at2", t.access_token);
  localStorage.setItem("sp_exp2", Date.now() + t.expires_in * 1000);
  return t.access_token;
}

function spUpdateStatus2() {
  const ok = !!localStorage.getItem("sp_rt2");
  if ($("spStatus2")) { $("spStatus2").textContent = ok ? "● Connected" : "○ Not connected"; $("spStatus2").style.color = ok ? "var(--ok)" : "var(--dim)"; }
  if ($("btnSpConnect2"))    $("btnSpConnect2").textContent = ok ? "Reconnect" : "Connect Spotify";
  if ($("btnSpDisconnect2")) $("btnSpDisconnect2").style.display = ok ? "" : "none";
  if ($("btnSpAuto2"))       $("btnSpAuto2").disabled = !ok;
  if ($("spSetupHint2"))     $("spSetupHint2").style.display = ok ? "none" : "";
  const cid = localStorage.getItem("sp_cid2");
  if (cid && $("spClientId2")) $("spClientId2").value = cid;
}

let spCurrentId2=null, spAutoTimer2=null, spStaticTimer2=null;
async function spCheck2() {
  try {
    const token = await spToken2(); if (!token) return;
    const r = await fetch("https://api.spotify.com/v1/me/player/currently-playing",
      { headers: { Authorization: "Bearer " + token } });
    if (r.status === 204 || !r.ok) return;
    const d = await r.json();
    if (!d || !d.item || !d.is_playing) return;
    if (d.item.id === spCurrentId2) return;
    spCurrentId2 = d.item.id;
    const text = (d.item.artists.map(a=>a.name).join(", ") + " - " + d.item.name).toUpperCase();
    clearTimeout(spStaticTimer2);
    await sendCmd({ type: "text", text, anim: "marquee", delay: 74, loop: 1 });
    const scrollMs = (28 + Math.ceil(text.length * 6.2)) * 74 + 1500;
    spStaticTimer2 = setTimeout(() => sendCmd({ type: "text", text, anim: "none", delay: 74, loop: 1 }), scrollMs);
  } catch(e) { console.warn("Spotify:", e); }
}

function spToggleAuto2() {
  const btn = $("btnSpAuto2");
  if (spAutoTimer2) {
    clearInterval(spAutoTimer2); spAutoTimer2=null;
    clearTimeout(spStaticTimer2); spStaticTimer2=null; spCurrentId2=null;
    btn.textContent="▶ Auto-update when song changes"; btn.classList.remove("active-state");
    localStorage.removeItem("sp_auto2");
  } else {
    spCheck2(); spAutoTimer2=setInterval(spCheck2,30000);
    btn.textContent="⏹ Stop auto-update"; btn.classList.add("active-state");
    localStorage.setItem("sp_auto2","1");
  }
}

$("btnSpConnect2").addEventListener("click", spConnect2);
$("btnSpDisconnect2").addEventListener("click", () => {
  if (spAutoTimer2) { clearInterval(spAutoTimer2); spAutoTimer2=null; spCurrentId2=null; }
  ["sp_at2","sp_rt2","sp_exp2","sp_v2","sp_cid2"].forEach(k=>localStorage.removeItem(k));
  spUpdateStatus2(); toast("Disconnected","ok");
});
$("btnSpAuto2").addEventListener("click", spToggleAuto2);

// Handle OAuth callback (sp_code in URL)
(async () => {
  const p = new URLSearchParams(location.search);
  const code = p.get("sp_code");
  if (code) {
    history.replaceState({}, "", "/");
    try { await spExchange2(code); toast("Spotify connected ✓","ok"); }
    catch(e) { toast("Spotify auth failed: " + e.message,"err"); }
  }
  spUpdateStatus2();
  if (localStorage.getItem("sp_auto2")==="1")
    setTimeout(()=>{ if($("btnSpAuto2")&&!$("btnSpAuto2").disabled) spToggleAuto2(); },600);
})();

// ── Admin ─────────────────────────────────────────────────────
let isAdmin = false;
let unsubUsers = null;

function renderUsers(snapshot) {
  const pending = [], approved = [];
  snapshot.forEach(d => {
    const u = { id: d.id, ...d.data() };
    if (u.status === "approved") approved.push(u); else pending.push(u);
  });
  function renderList(containerId, users, showActions) {
    const el = $(containerId);
    if (!users.length) { el.innerHTML = '<p class="hint">None.</p>'; return; }
    el.innerHTML = "";
    users.forEach(u => {
      const row = document.createElement("div"); row.className = "user-row";
      const badge = `<span class="badge ${u.status}">${u.status}</span>`;
      row.innerHTML = `<img src="${u.photo||""}" onerror="this.src=''">
        <div class="info"><div class="name">${u.name||"Unknown"}</div>
        <div class="email">${badge}${u.email||""}</div></div>
        <div class="actions">
          ${showActions && u.status!=="approved"  ? `<button data-uid="${u.id}" data-action="approve">✓</button>` : ""}
          ${showActions && u.status!=="rejected"  ? `<button data-uid="${u.id}" data-action="reject">✗</button>` : ""}
        </div>`;
      el.appendChild(row);
    });
    el.querySelectorAll("[data-action]").forEach(btn => {
      btn.addEventListener("click", async () => {
        const status = btn.dataset.action === "approve" ? "approved" : "rejected";
        await updateDoc(doc(db, "users", btn.dataset.uid), { status });
      });
    });
  }
  renderList("userListPending",  pending,  true);
  renderList("userListApproved", approved, true);
}

$("btnSaveLocal").addEventListener("click", () => {
  const url = $("localUrlInput").value.trim();
  if (url) { localStorage.setItem("localDeviceUrl", url); toast("Saved","ok"); updateLocalBanner(); }
});
$("localUrlInput").value = localStorage.getItem("localDeviceUrl") || "";

// ── Auth state ────────────────────────────────────────────────
onAuthStateChanged(auth, async user => {
  if (!user) { show("authScreen"); return; }

  // Upsert user doc (only if missing or pending)
  const uRef = doc(db, "users", user.uid);
  const snap = await getDoc(uRef);
  if (!snap.exists()) {
    await setDoc(uRef, {
      email: user.email, name: user.displayName,
      photo: user.photoURL, status: "pending",
      createdAt: Date.now()
    });
  }

  isAdmin = ADMINS.includes(user.email);

  // Re-read to get current status
  const current = (await getDoc(uRef)).data();
  if (!isAdmin && current.status !== "approved") {
    // Show pending screen
    show("pendingScreen");
    $("pendingUser").textContent = user.email;
    return;
  }

  // Approved (or admin) — show app
  show("app");
  $("userAvatar").src  = user.photoURL || "";
  $("userName").textContent = user.displayName?.split(" ")[0] || user.email;
  if (isAdmin) $("adminTabBtn").style.display = "";
  updateLocalBanner();
  $("statusBar").innerHTML = '<span class="ok">● Connected to Firebase</span>';

  if (isAdmin) {
    // Subscribe to all users for admin panel
    unsubUsers = onSnapshot(collection(db, "users"), renderUsers);
  }
});

$("btnGoogle").addEventListener("click", () => signInWithPopup(auth, new GoogleAuthProvider()));
$("btnSignOut").addEventListener("click",  async () => { if(unsubUsers) unsubUsers(); await signOut(auth); show("authScreen"); });
$("btnSignOut2").addEventListener("click", async () => { await signOut(auth); show("authScreen"); });
</script>
</body>
</html>
